{
  "name": "site-manifest",
  "version": "0.3.0",
  "description": "JSON-Schema-backed site manifest contract for labels and sections",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "keywords": [
    "schema",
    "manifest",
    "labels",
    "sections",
    "json-schema"
  ],
  "author": "Matthew Bub",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/matthewbub/site-manifest.git"
  },
  "homepage": "https://github.com/matthewbub/site-manifest#readme",
  "bugs": {
    "url": "https://github.com/matthewbub/site-manifest/issues"
  },
  "packageManager": "pnpm@10.30.1",
  "files": [
    "dist",
    "src/schema/site-manifest.schema.json",
    "README.md",
    "docs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": "./src/schema/site-manifest.schema.json"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.0.18",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
